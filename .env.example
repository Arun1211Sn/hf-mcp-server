# ─── Hugging Face MCP fork — local stdio config (copy to .env) ─────────────────
# In stdio mode the token is read from DEFAULT_HF_TOKEN (auth-utils.ts:55).
# Keep HF_TOKEN in sync for the code paths that read it. READ scope minimum;
# WRITE/FINEGRAINED needed for create_repo / duplicate_space / hf_jobs.
# Get a token at https://huggingface.co/settings/tokens
DEFAULT_HF_TOKEN=hf_xxx
HF_TOKEN=hf_xxx

# Transport is set by the entrypoint (stdio.js forces STDIO), so don't pin TRANSPORT.
NODE_ENV=production

# Skip the per-Space MCP handshake → faster Gradio calls
GRADIO_SKIP_INITIALIZE=true

# Whenever hf_doc_search runs, auto-enable hf_doc_fetch
SEARCH_ENABLES_FETCH=true

# ─── IMPORTANT ────────────────────────────────────────────────────────────────
# Leave USER_CONFIG_API UNSET. Unset => local mode => patched DEFAULT_SPACE_TOOLS +
# all built-in tools (incl. dynamic_space), bypassing HF's hosted "max spaces" cap.
# Setting it switches to external mode and re-imposes the hosted restrictions.
#
# Optional:
# PROXY_TOOLS_CSV=...    # register external StreamableHTTP MCP servers as tools
# DYNAMIC_SPACE_DATA=... # restrict dynamic_space to a curated CSV of spaces
